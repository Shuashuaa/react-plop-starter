const UPDATE_METHOD = "put" as "put" | "patch";

// Single-item responses wrap in `item` ({ message, item: {...} });
// list responses wrap in `data` ({ data: [...], nextToken, count }).
const unwrapItem = (data: unknown): unknown =>
  (data as { item?: unknown })?.item ?? data;
const unwrapList = (data: unknown): unknown =>
  (data as { data?: unknown })?.data ?? data;
