import { useQuery, useMutation, useInfiniteQuery, useQueryClient } from "@tanstack/react-query";
import { {{camelCase name}}Service } from "./{{camelCase name}}.service";
import { type Create{{pascalCase name}}Input, type Update{{pascalCase name}}Input } from "./{{camelCase name}}.schema";

const KEYS = {
    one: (id: string) => ["{{kebabCase name}}", id] as const,
    list: ["{{pluralize (kebabCase name)}}-list"] as const,
    infinite: ["{{pluralize (kebabCase name)}}-infinite"] as const,
};

// Fetch a single item by ID
export const use{{pascalCase name}} = (id: string | null) => {
    return useQuery({
        queryKey: id ? KEYS.one(id) : [],
        queryFn: () => {{camelCase name}}Service.getById(id!),
        enabled: !!id,
    });
};

// Fetch the full list (small datasets)
export const use{{pluralize (pascalCase name)}} = () => {
    return useQuery({
        queryKey: KEYS.list,
        queryFn: () => {{camelCase name}}Service.getAll(),
    });
};

// Paginated fetch — DynamoDB LastEvaluatedKey cursor pattern
export const useInfinite{{pluralize (pascalCase name)}} = () => {
    return useInfiniteQuery({
        queryKey: KEYS.infinite,
        queryFn: ({ pageParam }) => {{camelCase name}}Service.getPage(pageParam),
        initialPageParam: undefined as string | undefined,
        getNextPageParam: (lastPage) => lastPage.nextCursor,
    });
};

export const useCreate{{pascalCase name}} = () => {
    const queryClient = useQueryClient();
    return useMutation({
        mutationFn: (payload: Create{{pascalCase name}}Input) => {{camelCase name}}Service.create(payload),
        onSuccess: () => {
            queryClient.invalidateQueries({ queryKey: KEYS.list });
            queryClient.invalidateQueries({ queryKey: KEYS.infinite });
        },
    });
};

export const useUpdate{{pascalCase name}} = () => {
    const queryClient = useQueryClient();
    return useMutation({
        mutationFn: ({ id, payload }: { id: string; payload: Update{{pascalCase name}}Input }) =>
            {{camelCase name}}Service.update(id, payload),
        onSuccess: (_, { id }) => {
            queryClient.invalidateQueries({ queryKey: KEYS.one(id) });
            queryClient.invalidateQueries({ queryKey: KEYS.list });
            queryClient.invalidateQueries({ queryKey: KEYS.infinite });
        },
    });
};

export const useDelete{{pascalCase name}} = () => {
    const queryClient = useQueryClient();
    return useMutation({
        mutationFn: (id: string) => {{camelCase name}}Service.delete(id),
        onSuccess: () => {
            queryClient.invalidateQueries({ queryKey: KEYS.list });
            queryClient.invalidateQueries({ queryKey: KEYS.infinite });
        },
    });
};
