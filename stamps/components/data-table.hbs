/**
 * [AI GUARDRAIL DIRECTIVE]
 * 1. DO NOT change the use{{pluralize (pascalCase name)}}() data fetch, the error branch,
 *    the `filtered` search memo, or the <Table> pagination/loading wiring.
 * 2. AntD <Table> owns sort/filter/paginate. Columns are defined ONCE in the
 *    `columns` AI GENERATION ZONE as ColumnsType — add a `sorter` per column to
 *    enable sorting; add column `filters` + `onFilter` for per-column filtering.
 * 3. Use only `dataIndex`/`key`s that exist on the {{pascalCase name}} schema.
 * 4. onEdit/onDelete are optional row-action callbacks (wired by {{pascalCase name}}Manager).
 *    When passed, an Actions column is appended automatically — do not add it to
 *    `columns` yourself, and do not mutate data here.
 */

import { useMemo, useState } from "react";
import { Table, Button, Space, Alert, Input } from "antd";
import type { ColumnsType } from "antd/es/table";
import { Pencil, Trash2 } from "lucide-react";
import { use{{pluralize (pascalCase name)}}, type {{pascalCase name}} } from "@/features/{{camelCase name}}";

interface {{pascalCase name}}DataTableProps {
  onEdit?: (item: {{pascalCase name}}) => void;
  onDelete?: (item: {{pascalCase name}}) => void;
}

/* ==========================================================================
 * AI GENERATION ZONE (columns): one column per visible field.
 * @AI_TASK: Replace/extend using {{pascalCase name}} schema keys.
 *           - `dataIndex` must match a {{pascalCase name}} field exactly.
 *           - Add `sorter: (a, b) => ...` to make a column sortable.
 * ========================================================================== */
const columns: ColumnsType<{{pascalCase name}}> = [
  {
    title: "ID",
    dataIndex: "id",
    key: "id",
    sorter: (a, b) => String(a.id).localeCompare(String(b.id)),
  },
  {
    title: "Name",
    dataIndex: "name",
    key: "name",
    sorter: (a, b) => a.name.localeCompare(b.name),
  },
];
/* ===================== END AI GENERATION ZONE (columns) ================== */

export const {{pascalCase name}}DataTable = ({ onEdit, onDelete }: {{pascalCase name}}DataTableProps = {}) => {
  const { data: {{camelCase (pluralize name)}}, error, isLoading } = use{{pluralize (pascalCase name)}}();
  const [search, setSearch] = useState("");

  // Row actions are appended as a trailing column when wired by the Manager.
  const tableColumns: ColumnsType<{{pascalCase name}}> =
    onEdit || onDelete
      ? [
          ...columns,
          {
            title: "Actions",
            key: "actions",
            align: "right",
            render: (_, item) => (
              <Space>
                {{lb}}onEdit && (
                  <Button
                    type="link"
                    size="small"
                    icon={<Pencil className="w-4 h-4" />}
                    onClick={() => onEdit(item)}
                  >
                    Edit
                  </Button>
                ){{rb}}
                {{lb}}onDelete && (
                  <Button
                    type="link"
                    size="small"
                    danger
                    icon={<Trash2 className="w-4 h-4" />}
                    onClick={() => onDelete(item)}
                  >
                    Delete
                  </Button>
                ){{rb}}
              </Space>
            ),
          },
        ]
      : columns;

  // Global search across all fields. Per-column filters live on the columns above.
  const filtered = useMemo(() => {
    const rows = {{camelCase (pluralize name)}} ?? [];
    const q = search.trim().toLowerCase();
    if (!q) return rows;
    return rows.filter((row) =>
      Object.values(row).some((value) => String(value).toLowerCase().includes(q))
    );
  }, [{{camelCase (pluralize name)}}, search]);

  if (error) {
    return (
      <Alert
        type="error"
        showIcon
        message={error instanceof Error ? error.message : "Failed to load"}
      />
    );
  }

  return (
    <div className="space-y-4">
      <Input.Search
        placeholder="Search {{lowerCase (pluralize name)}}..."
        allowClear
        value={search}
        onChange={(e) => setSearch(e.target.value)}
        className="max-w-xs"
      />
      <Table<{{pascalCase name}}>
        rowKey="id"
        columns={tableColumns}
        dataSource={filtered}
        loading={isLoading}
        pagination={{lb}}{ pageSize: 5, showSizeChanger: false }{{rb}}
      />
    </div>
  );
};
