/**
 * [AI GUARDRAIL DIRECTIVE]
 * 1. DO NOT change the loading/error branches or the use{{pluralize (pascalCase name)}}() data fetch.
 * 2. DO NOT alter the useReactTable() setup (it consumes `tableColumns`), the
 *    getCoreRowModel/getSortedRowModel/getFilteredRowModel/getPaginationRowModel
 *    wiring, the `actions` column block, or the flexRender() calls.
 * 3. Columns are defined ONCE in the `columns` AI GENERATION ZONE as a ColumnDef[].
 *    Add/edit column objects there only — header markup and cells render from it.
 * 4. Use only `accessorKey`s that exist on the {{pascalCase name}} schema.
 * 5. onEdit/onDelete are optional row-action callbacks (wired by {{pascalCase name}}Manager).
 *    When passed, an Actions column is appended automatically — do not add it to
 *    `columns` yourself, and do not mutate data here.
 */

import { useState } from "react";
import { Pencil, Trash2 } from "lucide-react";
import {
  useReactTable,
  getCoreRowModel,
  getSortedRowModel,
  getFilteredRowModel,
  getPaginationRowModel,
  flexRender,
  type ColumnDef,
  type SortingState,
} from "@tanstack/react-table";
import { use{{pluralize (pascalCase name)}}, type {{pascalCase name}} } from "@/features/{{camelCase name}}";

interface {{pascalCase name}}DataTableProps {
  onEdit?: (item: {{pascalCase name}}) => void;
  onDelete?: (item: {{pascalCase name}}) => void;
}

/* ==========================================================================
 * AI GENERATION ZONE (columns): define one ColumnDef per visible field.
 * @AI_TASK: Replace/extend the columns below using {{pascalCase name}} schema keys.
 *           - `accessorKey` must match a {{pascalCase name}} field exactly.
 *           - Set `enableSorting: false` for non-sortable columns.
 *           - Use the optional `cell` for custom formatting (dates, badges, etc.).
 * ========================================================================== */
const columns: ColumnDef<{{pascalCase name}}>[] = [
  {
    accessorKey: "id",
    header: "ID",
  },
  {
    accessorKey: "name",
    header: "Name",
  },
];
/* ===================== END AI GENERATION ZONE (columns) ================== */

export const {{pascalCase name}}DataTable = ({ onEdit, onDelete }: {{pascalCase name}}DataTableProps = {}) => {
  const { data: {{camelCase (pluralize name)}}, error, isLoading } = use{{pluralize (pascalCase name)}}();
  const [sorting, setSorting] = useState<SortingState>([]);
  const [globalFilter, setGlobalFilter] = useState("");

  // Row actions are appended as a non-sortable trailing column when wired.
  const tableColumns: ColumnDef<{{pascalCase name}}>[] =
    onEdit || onDelete
      ? [
          ...columns,
          {
            id: "actions",
            header: "Actions",
            enableSorting: false,
            enableGlobalFilter: false,
            cell: ({ row }) => (
              <div className="text-right whitespace-nowrap">
                {{lb}}onEdit && (
                  <button
                    type="button"
                    onClick={{lb}}() => onEdit(row.original){{rb}}
                    className="inline-flex items-center gap-1 text-sm font-medium text-blue-600 hover:text-blue-700 mr-3"
                  >
                    <Pencil className="w-4 h-4" />
                    Edit
                  </button>
                ){{rb}}
                {{lb}}onDelete && (
                  <button
                    type="button"
                    onClick={{lb}}() => onDelete(row.original){{rb}}
                    className="inline-flex items-center gap-1 text-sm font-medium text-red-600 hover:text-red-700"
                  >
                    <Trash2 className="w-4 h-4" />
                    Delete
                  </button>
                ){{rb}}
              </div>
            ),
          },
        ]
      : columns;

  // TanStack Table's useReactTable returns functions the React Compiler can't
  // memoize; its internal state is stable, so opting this call out is safe.
  // eslint-disable-next-line react-hooks/incompatible-library
  const table = useReactTable({
    data: {{camelCase (pluralize name)}} ?? [],
    columns: tableColumns,
    initialState: { pagination: { pageSize: 5 } },
    state: { sorting, globalFilter },
    onSortingChange: setSorting,
    onGlobalFilterChange: setGlobalFilter,
    getCoreRowModel: getCoreRowModel(),
    getSortedRowModel: getSortedRowModel(),
    getFilteredRowModel: getFilteredRowModel(),
    getPaginationRowModel: getPaginationRowModel(),
  });

  if (isLoading) {
    return <div className="text-sm text-slate-500 p-6">Loading {{lowerCase (pluralize name)}}...</div>;
  }

  if (error) {
    return (
      <div className="text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2 m-6">
        Error: {error instanceof Error ? error.message : "Failed to load"}
      </div>
    );
  }

  return (
    <div className="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <div className="p-4 border-b border-slate-200">
        <input
          type="text"
          value={globalFilter}
          onChange={(e) => setGlobalFilter(e.target.value)}
          placeholder="Search {{lowerCase (pluralize name)}}..."
          className="w-full max-w-xs text-sm rounded-lg border border-slate-200 px-3 py-2 outline-none focus:border-slate-400"
        />
      </div>

      <table className="w-full">
        <thead>
          {{lb}}table.getHeaderGroups().map((headerGroup) => (
            <tr key={{lb}}headerGroup.id{{rb}} className="bg-slate-50">
              {{lb}}headerGroup.headers.map((header) => {
                const canSort = header.column.getCanSort();
                return (
                  <th
                    key={{lb}}header.id{{rb}}
                    onClick={{lb}}canSort ? header.column.getToggleSortingHandler() : undefined{{rb}}
                    className={`text-xs font-semibold text-slate-500 uppercase tracking-wide px-4 py-3 text-left ${
                      canSort ? "cursor-pointer select-none hover:text-slate-700" : ""
                    }`}
                  >
                    {{lb}}flexRender(header.column.columnDef.header, header.getContext()){{rb}}
                    {{lb}}{ asc: " ▲", desc: " ▼" }[header.column.getIsSorted() as string] ?? ""{{rb}}
                  </th>
                );
              }){{rb}}
            </tr>
          )){{rb}}
        </thead>
        <tbody>
          {{lb}}table.getRowModel().rows.length === 0 && (
            <tr>
              <td colSpan={{lb}}tableColumns.length{{rb}} className="text-center py-10">
                <p className="text-sm text-slate-500">No {{lowerCase (pluralize name)}} found</p>
              </td>
            </tr>
          ){{rb}}
          {{lb}}table.getRowModel().rows.map((row) => (
            <tr key={{lb}}row.id{{rb}} className="hover:bg-slate-50 border-t border-slate-200">
              {{lb}}row.getVisibleCells().map((cell) => (
                <td key={{lb}}cell.id{{rb}} className="text-sm text-slate-700 px-4 py-3">
                  {{lb}}flexRender(cell.column.columnDef.cell, cell.getContext()){{rb}}
                </td>
              )){{rb}}
            </tr>
          )){{rb}}
        </tbody>
      </table>

      <div className="flex items-center justify-between px-4 py-3 border-t border-slate-200">
        <span className="text-xs text-slate-500">
          Page {{lb}}table.getState().pagination.pageIndex + 1{{rb}} of {{lb}}table.getPageCount() || 1{{rb}}
        </span>
        <div className="flex gap-2">
          <button
            onClick={{lb}}() => table.previousPage(){{rb}}
            disabled={{lb}}!table.getCanPreviousPage(){{rb}}
            className="text-sm rounded-lg border border-slate-200 px-3 py-1.5 disabled:opacity-40 hover:bg-slate-50"
          >
            Previous
          </button>
          <button
            onClick={{lb}}() => table.nextPage(){{rb}}
            disabled={{lb}}!table.getCanNextPage(){{rb}}
            className="text-sm rounded-lg border border-slate-200 px-3 py-1.5 disabled:opacity-40 hover:bg-slate-50"
          >
            Next
          </button>
        </div>
      </div>
    </div>
  );
};
