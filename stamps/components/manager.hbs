/**
 * [AI GUARDRAIL DIRECTIVE]
 * 1. This component owns CRUD UI state (create/edit modal, delete confirm) and
 *    wires the use{{pascalCase name}} mutation hooks. DO NOT fetch data here —
 *    the table component owns the list query.
 * 2. DELETE works out of the box (id only, confirmed via App modal) — keep its flow.
 * 3. CREATE/EDIT reuse the same <{{pascalCase name}}Form/> inside an AntD <Modal>. The
 *    form WILL submit on click as-is; customise its fields in {{pascalCase name}}Form.tsx
 *    + the schema to match your real payload. DO NOT change the mutateAsync calls here.
 * 4. Modal title text, button labels, and toolbar layout are the AI GENERATION ZONE —
 *    restyle there. Keep the handlers and hook calls intact.
 */

import { useState } from "react";
import { Plus } from "lucide-react";
import { App, Button, Modal } from "antd";
import {
  useCreate{{pascalCase name}},
  useUpdate{{pascalCase name}},
  useDelete{{pascalCase name}},
  type {{pascalCase name}},
  type Create{{pascalCase name}}Input,
} from "@/features/{{camelCase name}}";
import { {{tableComponent}} } from "@/components/{{tableComponent}}";
import { {{pascalCase name}}Form } from "@/components/{{pascalCase name}}Form";

type Mode = "create" | "edit" | null;

export const {{pascalCase name}}Manager = () => {
  const { modal } = App.useApp();
  const createMutation = useCreate{{pascalCase name}}();
  const updateMutation = useUpdate{{pascalCase name}}();
  const deleteMutation = useDelete{{pascalCase name}}();

  const [mode, setMode] = useState<Mode>(null);
  const [selected, setSelected] = useState<{{pascalCase name}} | null>(null);

  const closeForm = () => {
    setMode(null);
    setSelected(null);
  };

  // Same form handles create and edit. Create input satisfies the (partial)
  // update payload, so we forward `data` unchanged.
  const handleSubmit = async (data: Create{{pascalCase name}}Input) => {
    if (mode === "edit" && selected) {
      await updateMutation.mutateAsync({ id: selected.id, payload: data });
    } else {
      await createMutation.mutateAsync(data);
    }
    closeForm();
  };

  // Confirm via App.modal so it inherits ConfigProvider theme. onOk returns the
  // mutation promise, so the confirm button shows a spinner until it resolves.
  const handleDelete = (item: {{pascalCase name}}) => {
    modal.confirm({
      title: "Delete {{lowerCase name}}?",
      content: "This action cannot be undone.",
      okText: "Delete",
      okButtonProps: { danger: true },
      cancelText: "Cancel",
      onOk: () => deleteMutation.mutateAsync(item.id),
    });
  };

  return (
    <div className="space-y-4">
      {/* ====================================================================
        * AI GENERATION ZONE (toolbar): page-level actions. Restyle freely.
        * ==================================================================== */}
      <div className="flex justify-end">
        <Button
          type="primary"
          icon={<Plus className="w-4 h-4" />}
          onClick={() => {
            setSelected(null);
            setMode("create");
          }}
        >
          New {{titleCase name}}
        </Button>
      </div>
      {/* ===================== END AI GENERATION ZONE (toolbar) ============= */}

      <{{tableComponent}}
        onEdit={(item) => {
          setSelected(item);
          setMode("edit");
        }}
        onDelete={handleDelete}
      />

      {/* Create / Edit modal — shared form. Keyed + destroyed so defaults reset. */}
      <Modal
        title={mode === "edit" ? "Edit {{titleCase name}}" : "New {{titleCase name}}"}
        open={mode !== null}
        onCancel={closeForm}
        footer={null}
        destroyOnHidden
      >
        <{{pascalCase name}}Form
          key={selected?.id ?? "new"}
          onSubmit={handleSubmit}
          defaultValues={mode === "edit" && selected ? selected : undefined}
        />
      </Modal>
    </div>
  );
};
