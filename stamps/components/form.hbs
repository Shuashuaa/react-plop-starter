import { useForm, Controller } from "react-hook-form";
import { zodResolver } from "@hookform/resolvers/zod";
import { useState } from "react";
import { Form, Input, Button, Alert } from "antd";
import { Create{{pascalCase name}}Schema, type Create{{pascalCase name}}Input } from "@/features/{{camelCase name}}";

/**
 * [AI GUARDRAIL DIRECTIVE]
 * 1. DO NOT change the component signature, RHF setup, or handleFormSubmit logic.
 * 2. Validation comes from Create{{pascalCase name}}Schema via zodResolver — edit the
 *    schema first, then add matching fields inside the AI GENERATION ZONE.
 * 3. RHF + zod is the source of truth. DO NOT switch to AntD's own <Form> data
 *    collection: the <Form> here is layout-only (component={false}, no `name` on
 *    Form.Item). Wire every input through <Controller name="fieldName"> with exact
 *    schema keys, and surface errors via Form.Item validateStatus/help.
 * 4. Use AntD inputs (Input, InputNumber, Select, DatePicker, etc.) — no inline styles.
 */

interface {{pascalCase name}}FormProps {
  onSubmit: (data: Create{{pascalCase name}}Input) => Promise<void>;
  defaultValues?: Partial<Create{{pascalCase name}}Input>;
}

export const {{pascalCase name}}Form = ({ onSubmit, defaultValues }: {{pascalCase name}}FormProps) => {
  const [serverError, setServerError] = useState<string | null>(null);

  const {
    control,
    handleSubmit,
    formState: { errors, isSubmitting },
  } = useForm<Create{{pascalCase name}}Input>({
    resolver: zodResolver(Create{{pascalCase name}}Schema),
    defaultValues,
  });

  const handleFormSubmit = async (data: Create{{pascalCase name}}Input) => {
    try {
      setServerError(null);
      await onSubmit(data);
    } catch {
      setServerError("Something went wrong. Please try again.");
    }
  };

  return (
    <form onSubmit={handleSubmit(handleFormSubmit)}>
      {/* component={false} => no nested <form>; Form is layout/context only. */}
      <Form component={false} layout="vertical">
        {serverError && (
          <Alert type="error" showIcon message={serverError} className="mb-4" />
        )}

        {/* ==================================================================
          * AI GENERATION ZONE: one <Controller> + <Form.Item> block per field.
          * @AI_TASK: Mirror this block for each Create{{pascalCase name}}Schema field.
          *           Keep Controller `name` identical to the schema key.
          * ================================================================== */}
        <Controller
          name="name"
          control={control}
          render={({ field }) => (
            <Form.Item
              label="Name"
              required
              validateStatus={errors.name ? "error" : undefined}
              help={errors.name?.message}
            >
              <Input {...field} />
            </Form.Item>
          )}
        />
        {/* ===================== END AI GENERATION ZONE ===================== */}

        <Button type="primary" htmlType="submit" loading={isSubmitting} block>
          Save
        </Button>
      </Form>
    </form>
  );
};
