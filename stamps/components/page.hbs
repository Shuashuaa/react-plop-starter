import { useState } from "react";
import { {{pascalCase name}}Table } from "@/components/{{pascalCase name}}Table";
import { {{pascalCase name}}Form } from "@/components/{{pascalCase name}}Form";
import {
    useCreate{{pascalCase name}},
    useUpdate{{pascalCase name}},
    useDelete{{pascalCase name}},
    type Create{{pascalCase name}}Input,
    type {{pascalCase name}},
} from "@/features/{{camelCase name}}";

export const {{pascalCase name}}Page = () => {
    const [editing, setEditing] = useState<{{pascalCase name}} | null>(null);
    const [showCreate, setShowCreate] = useState(false);

    const { mutate: create{{pascalCase name}}, isPending: creating } = useCreate{{pascalCase name}}();
    const { mutate: update{{pascalCase name}}, isPending: updating } = useUpdate{{pascalCase name}}();
    const { mutate: delete{{pascalCase name}} } = useDelete{{pascalCase name}}();

    const handleCreate = (data: Create{{pascalCase name}}Input) => {
        create{{pascalCase name}}(data, { onSuccess: () => setShowCreate(false) });
    };

    const handleUpdate = (data: Create{{pascalCase name}}Input) => {
        if (!editing) return;
        update{{pascalCase name}}(
            { id: editing.id, payload: data },
            { onSuccess: () => setEditing(null) }
        );
    };

    const handleDelete = (id: string) => {
        if (!confirm("Delete this {{lowerCase name}}?")) return;
        delete{{pascalCase name}}(id);
    };

    return (
        <div className="p-6 max-w-5xl mx-auto space-y-6">
            <div className="flex items-center justify-between">
                <h1 className="text-2xl font-bold text-gray-900">{{titleCase (pluralize name)}}</h1>
                <button
                    onClick={() => { setShowCreate((v) => !v); setEditing(null); }}
                    className="px-4 py-2 text-sm font-medium bg-gray-900 text-white rounded-lg hover:bg-gray-700"
                >
                    {showCreate ? "Cancel" : "+ New {{pascalCase name}}"}
                </button>
            </div>

            {showCreate && (
                <div className="bg-white rounded-lg border border-gray-200 p-6">
                    <h2 className="font-semibold mb-4">New {{pascalCase name}}</h2>
                    <{{pascalCase name}}Form onSubmit={handleCreate} />
                    {creating && <p className="text-sm text-gray-500 mt-2">Saving…</p>}
                </div>
            )}

            {editing && (
                <div className="bg-white rounded-lg border border-blue-200 p-6">
                    <div className="flex items-center justify-between mb-4">
                        <h2 className="font-semibold">Edit — {editing.{{camelCase displayField}}}</h2>
                        <button
                            onClick={() => setEditing(null)}
                            className="text-sm text-gray-500 hover:text-gray-700"
                        >
                            Cancel
                        </button>
                    </div>
                    <{{pascalCase name}}Form onSubmit={handleUpdate} defaultValues={editing} />
                    {updating && <p className="text-sm text-gray-500 mt-2">Saving…</p>}
                </div>
            )}

            <{{pascalCase name}}Table
                onEdit={(item) => { setEditing(item); setShowCreate(false); }}
                onDelete={handleDelete}
            />
        </div>
    );
};
