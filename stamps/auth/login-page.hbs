import { useState } from 'react';
import { useForm, Controller } from 'react-hook-form';
import { useNavigate } from 'react-router-dom';
import { signIn, signUp, confirmSignUp } from 'aws-amplify/auth';
import { Card, Segmented, Form, Input, Button, Alert, Typography } from 'antd';
import { useAuthGuard } from '@/hooks/useAuth';

const { Title, Text } = Typography;

type View = 'login' | 'signup' | 'confirm';
type FormValues = { name: string; email: string; password: string; confirmPassword: string; code: string };
type Status = { type: 'error' | 'success'; message: string } | null;

export default function LoginPage() {
  const navigate = useNavigate();
  const { loading } = useAuthGuard(false);
  const [view, setView] = useState<View>('login');
  const [status, setStatus] = useState<Status>(null);

  const { handleSubmit, getValues, watch, reset, control, formState: { isSubmitting, errors } } = useForm<FormValues>({
    defaultValues: { name: '', email: '', password: '', confirmPassword: '', code: '' },
  });

  function switchView(v: View) {
    reset({ name: getValues('name'), email: getValues('email'), password: '', confirmPassword: '', code: '' });
    setStatus(null); setView(v);
  }

  async function onLogin({ email, password }: FormValues) {
    setStatus(null);
    try {
      const { isSignedIn } = await signIn({ username: email, password });
      if (isSignedIn) navigate('/');
    } catch (err: unknown) {
      setStatus({ type: 'error', message: err instanceof Error ? err.message : 'Sign in failed.' });
    }
  }

  async function onSignup({ name, email, password }: FormValues) {
    setStatus(null);
    try {
      const { nextStep } = await signUp({ username: email, password, options: { userAttributes: { email, name } } });
      if (nextStep.signUpStep === 'CONFIRM_SIGN_UP') { setStatus(null); setView('confirm'); }
    } catch (err: unknown) {
      setStatus({ type: 'error', message: err instanceof Error ? err.message : 'Sign up failed.' });
    }
  }

  async function onConfirm({ email, code }: FormValues) {
    setStatus(null);
    try {
      const { isSignUpComplete } = await confirmSignUp({ username: email, confirmationCode: code });
      if (isSignUpComplete) { switchView('login'); setStatus({ type: 'success', message: 'Account confirmed! You can now sign in.' }); }
    } catch (err: unknown) {
      setStatus({ type: 'error', message: err instanceof Error ? err.message : 'Confirmation failed.' });
    }
  }

  if (loading) return null;

  // RHF's watch() is stable; React Compiler can't verify it, so opt out here.
  // eslint-disable-next-line react-hooks/incompatible-library
  const pw = watch('password') ?? '';
  const pwRules = [
    { label: 'Min 8 chars', met: pw.length >= 8 },
    { label: 'Uppercase', met: /[A-Z]/.test(pw) },
    { label: 'Lowercase', met: /[a-z]/.test(pw) },
    { label: 'Number', met: /[0-9]/.test(pw) },
    { label: 'Symbol', met: /[^A-Za-z0-9]/.test(pw) },
  ];

  return (
    <div className="flex min-h-screen items-center justify-center bg-slate-50 px-4">
      <div className="w-full max-w-sm">
        <div className="mb-8 text-center">
          <Title level={2} style={{lb}}{ marginBottom: 4 }{{rb}}>Sign in</Title>
          <Text type="secondary">Cognito Authentication</Text>
        </div>

        <Card>
          {view !== 'confirm' && (
            <Segmented
              block
              className="mb-6"
              value={view}
              onChange={(v) => switchView(v as View)}
              options={[{ label: 'Sign In', value: 'login' }, { label: 'Sign Up', value: 'signup' }]}
            />
          )}

          {view === 'confirm' && (
            <div className="mb-6">
              <Title level={4} style={{lb}}{ marginBottom: 4 }{{rb}}>Check your email</Title>
              {/* eslint-disable-next-line react-hooks/incompatible-library */}
              <Text type="secondary">We sent a 6-digit code to <Text strong>{watch('email')}</Text></Text>
            </div>
          )}

          {status && (
            <Alert
              className="mb-4"
              showIcon
              type={status.type === 'error' ? 'error' : 'success'}
              message={status.message}
            />
          )}

          {view === 'login' && (
            <form onSubmit={handleSubmit(onLogin)}>
              <Form component={false} layout="vertical">
                <Controller
                  name="email"
                  control={control}
                  rules={{lb}}{ required: 'Email is required.' }{{rb}}
                  render={({ field }) => (
                    <Form.Item label="Email" required validateStatus={errors.email ? 'error' : undefined} help={errors.email?.message}>
                      <Input {...field} type="email" autoComplete="email" placeholder="you@example.com" />
                    </Form.Item>
                  )}
                />
                <Controller
                  name="password"
                  control={control}
                  rules={{lb}}{ required: 'Password is required.' }{{rb}}
                  render={({ field }) => (
                    <Form.Item label="Password" required validateStatus={errors.password ? 'error' : undefined} help={errors.password?.message}>
                      <Input.Password {...field} autoComplete="current-password" placeholder="••••••••" />
                    </Form.Item>
                  )}
                />
                <Button type="primary" htmlType="submit" loading={isSubmitting} block>Sign In</Button>
              </Form>
            </form>
          )}

          {view === 'signup' && (
            <form onSubmit={handleSubmit(onSignup)}>
              <Form component={false} layout="vertical">
                <Controller
                  name="name"
                  control={control}
                  rules={{lb}}{ required: 'Name is required.' }{{rb}}
                  render={({ field }) => (
                    <Form.Item label="Name" required validateStatus={errors.name ? 'error' : undefined} help={errors.name?.message}>
                      <Input {...field} autoComplete="name" placeholder="Jane Doe" />
                    </Form.Item>
                  )}
                />
                <Controller
                  name="email"
                  control={control}
                  rules={{lb}}{ required: 'Email is required.' }{{rb}}
                  render={({ field }) => (
                    <Form.Item label="Email" required validateStatus={errors.email ? 'error' : undefined} help={errors.email?.message}>
                      <Input {...field} type="email" autoComplete="email" placeholder="you@example.com" />
                    </Form.Item>
                  )}
                />
                <Controller
                  name="password"
                  control={control}
                  rules={{lb}}{ required: 'Password is required.', minLength: { value: 8, message: 'Min 8 characters.' } }{{rb}}
                  render={({ field }) => (
                    <Form.Item label="Password" required validateStatus={errors.password ? 'error' : undefined} help={errors.password?.message}>
                      <Input.Password {...field} autoComplete="new-password" placeholder="••••••••" />
                      <div className="mt-2 flex flex-wrap gap-x-3 gap-y-1">
                        {pwRules.map(({ label, met }) => (
                          <span key={label} className={`text-xs transition-colors ${met ? 'text-emerald-600' : 'text-slate-400'}`}>
                            {met ? '✓' : '·'} {label}
                          </span>
                        ))}
                      </div>
                    </Form.Item>
                  )}
                />
                <Controller
                  name="confirmPassword"
                  control={control}
                  rules={{lb}}{ required: 'Please confirm your password.', validate: (val) => val === getValues('password') || 'Passwords do not match.' }{{rb}}
                  render={({ field }) => (
                    <Form.Item label="Confirm Password" required validateStatus={errors.confirmPassword ? 'error' : undefined} help={errors.confirmPassword?.message}>
                      <Input.Password {...field} autoComplete="new-password" placeholder="••••••••" />
                    </Form.Item>
                  )}
                />
                <Button type="primary" htmlType="submit" loading={isSubmitting} block>Create Account</Button>
              </Form>
            </form>
          )}

          {view === 'confirm' && (
            <form onSubmit={handleSubmit(onConfirm)}>
              <Form component={false} layout="vertical">
                <Controller
                  name="code"
                  control={control}
                  rules={{lb}}{ required: 'Code is required.', minLength: { value: 6, message: 'Must be 6 digits.' } }{{rb}}
                  render={({ field }) => (
                    <Form.Item label="Verification Code" required validateStatus={errors.code ? 'error' : undefined} help={errors.code?.message}>
                      <Input
                        {...field}
                        inputMode="numeric"
                        maxLength={6}
                        placeholder="123456"
                        onChange={(e) => field.onChange(e.target.value.replace(/\D/g, ''))}
                        className="text-center font-mono text-lg tracking-widest"
                      />
                    </Form.Item>
                  )}
                />
                <Button type="primary" htmlType="submit" loading={isSubmitting} block>Confirm Account</Button>
                <Button type="link" block className="mt-2" onClick={() => switchView('signup')}>Back to sign up</Button>
              </Form>
            </form>
          )}
        </Card>
      </div>
    </div>
  );
}
