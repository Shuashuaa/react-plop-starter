import {
  BrowserRouter,
  Routes,
  Route,
  Link,
  Outlet,
  useNavigate,
  useOutletContext,
} from "react-router-dom";
import { signOut } from "aws-amplify/auth";
import { Button, Card, Space, Spin, Typography } from "antd";
import LoginPage from "@/pages/LoginPage";
import NotFoundPage from "@/pages/NotFoundPage";
import PlopCommands from "@/components/PlopCommands";
import { useAuthGuard, type AuthUser } from "@/hooks/useAuth";
/* PLOP_INJECT_IMPORT */

const { Title, Text } = Typography;

type AuthOutletContext = { user: AuthUser };

export function useAuthUser() {
  return useOutletContext<AuthOutletContext>().user;
}

function FullScreenSpinner() {
  return (
    <div className="min-h-screen flex items-center justify-center bg-slate-50">
      <Spin size="large" />
    </div>
  );
}

/**
 * Global auth gate. Every protected route is nested under this element, so
 * generated pages inherit the guard automatically. useAuthGuard(true) redirects
 * to /login when signed out; while bootstrapping, a spinner replaces the white
 * page flash. Children read the resolved user via useOutletContext / useAuthUser.
 */
function RequireAuth() {
  const { user, loading } = useAuthGuard(true);
  if (loading || !user) return <FullScreenSpinner />;
  const ctx: AuthOutletContext = { user };
  return <Outlet context={ctx} />;
}

/**
 * Protected landing. Generated pages register their route + nav link here via
 * the Page / Feature generators (PLOP_INJECT_* markers). DO NOT remove the
 * markers — plop needs them.
 */
function Dashboard() {
  const navigate = useNavigate();
  const user = useAuthUser();

  async function handleSignOut() {
    await signOut();
    navigate("/login");
  }

  return (
    <main className="bg-slate-50 p-6 min-h-screen">
      <div className="max-w-4xl mx-auto">
        <div className="flex items-center justify-between mb-6">
          <div>
            <Title level={3} style={{lb}}{ margin: 0 }{{rb}}>Dashboard</Title>
            <Text type="secondary">Welcome to your app.</Text>
          </div>
          <Space>
            <Text>Hello, <Text strong>{user.name}!</Text></Text>
            <Button onClick={handleSignOut}>Sign out</Button>
          </Space>
        </div>

        <Card className="mb-6">
          <h2 className="text-base font-semibold text-slate-900 mb-1">Pages</h2>
          <p className="text-sm text-slate-500 mb-4">Scaffolded pages register their link here.</p>
          <nav className="flex flex-wrap items-center gap-4">
            {/* PLOP_INJECT_LINK */}
          </nav>
        </Card>

        <Card title="Plop generators">
          <PlopCommands />
        </Card>
      </div>
    </main>
  );
}

export default function App() {
  return (
    <BrowserRouter>
      <Routes>
        <Route path="/login" element={<LoginPage />} />
        <Route element={<RequireAuth />}>
          <Route path="/" element={<Dashboard />} />
          {/* PLOP_INJECT_ROUTE */}
        </Route>
        <Route path="*" element={<NotFoundPage />} />
      </Routes>
    </BrowserRouter>
  );
}
