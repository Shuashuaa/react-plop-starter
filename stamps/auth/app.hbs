import { BrowserRouter, Routes, Route, Link, useNavigate } from "react-router-dom";
import { signOut } from "aws-amplify/auth";
import { Button, Card, Space, Typography } from "antd";
import LoginPage from "@/pages/LoginPage";
import { useAuthGuard } from "@/hooks/useAuth";
/* PLOP_INJECT_IMPORT */

const { Title, Text } = Typography;

/**
 * Protected landing. useAuthGuard(true) redirects to /login when signed out.
 * Generated pages register their route + nav link here via the Page / Feature
 * generators (PLOP_INJECT_* markers). DO NOT remove the markers — plop needs them.
 */
function Dashboard() {
  const navigate = useNavigate();
  const { user, loading } = useAuthGuard(true);

  async function handleSignOut() {
    await signOut();
    navigate("/login");
  }

  if (loading) return null;

  return (
    <main className="bg-slate-50 p-6 min-h-screen">
      <div className="max-w-4xl mx-auto">
        <div className="flex items-center justify-between mb-6">
          <div>
            <Title level={3} style={{lb}}{ margin: 0 }{{rb}}>Dashboard</Title>
            <Text type="secondary">Welcome to your app.</Text>
          </div>
          <Space>
            <Text>Hello, <Text strong>{user?.name}!</Text></Text>
            <Button onClick={handleSignOut}>Sign out</Button>
          </Space>
        </div>

        <Card>
          <nav className="flex flex-col gap-2">
            <Text type="secondary">Pages</Text>
            <Link to="/" className="text-sm text-blue-600 hover:text-blue-700">Dashboard</Link>
            {/* PLOP_INJECT_LINK */}
          </nav>
        </Card>
      </div>
    </main>
  );
}

export default function App() {
  return (
    <BrowserRouter>
      <Routes>
        <Route path="/login" element={<LoginPage />} />
        <Route path="/" element={<Dashboard />} />
        {/* PLOP_INJECT_ROUTE */}
      </Routes>
    </BrowserRouter>
  );
}
