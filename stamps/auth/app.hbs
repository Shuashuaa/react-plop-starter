import { BrowserRouter, Routes, Route, Link, useNavigate } from "react-router-dom";
import { signOut } from "aws-amplify/auth";
import LoginPage from "@/pages/LoginPage";
import { useAuthGuard } from "@/hooks/useAuth";
/* PLOP_INJECT_IMPORT */

/**
 * Protected landing. useAuthGuard(true) redirects to /login when signed out.
 * Generated pages register their route + nav link here via the Page / Feature
 * generators (PLOP_INJECT_* markers). DO NOT remove the markers — plop needs them.
 */
function Dashboard() {
  const navigate = useNavigate();
  const { user, loading } = useAuthGuard(true);

  async function handleSignOut() {
    await signOut();
    navigate("/login");
  }

  if (loading) return null;

  return (
    <main className="bg-slate-50 p-6 min-h-screen">
      <div className="max-w-4xl mx-auto">
        <div className="flex items-center justify-between mb-6">
          <div>
            <h1 className="text-xl font-bold text-slate-900">Dashboard</h1>
            <p className="text-sm text-slate-500">Welcome to your app.</p>
          </div>
          <div className="flex items-center gap-3">
            <span className="text-sm text-slate-600">
              Hello, <span className="font-bold">{user?.name}!</span>
            </span>
            <button
              onClick={handleSignOut}
              className="rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-slate-900"
            >
              Sign out
            </button>
          </div>
        </div>

        <nav className="flex flex-col gap-2 bg-white rounded-2xl border border-slate-200 p-6">
          <p className="text-sm text-slate-500 mb-1">Pages</p>
          <Link to="/" className="text-sm text-blue-600 hover:text-blue-700">Dashboard</Link>
          {/* PLOP_INJECT_LINK */}
        </nav>
      </div>
    </main>
  );
}

export default function App() {
  return (
    <BrowserRouter>
      <Routes>
        <Route path="/login" element={<LoginPage />} />
        <Route path="/" element={<Dashboard />} />
        {/* PLOP_INJECT_ROUTE */}
      </Routes>
    </BrowserRouter>
  );
}
